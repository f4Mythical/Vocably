<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Memory"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp"
            android:text="Dobierz pasujące pary"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UKŁAD PLANSZY"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_group"
            android:layout_marginBottom="40dp">

            <TextView
                android:id="@+id/btnGrid2x2"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="2 × 2   —   4 karty · 2 pary"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_btn_language" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <TextView
                android:id="@+id/btnGrid3x2"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="3 × 2   —   6 kart · 3 pary"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_btn_language_selected" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <TextView
                android:id="@+id/btnGrid4x2"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="4 × 2   —   8 kart · 4 pary"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_btn_language" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <TextView
                android:id="@+id/btnGrid4x4"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="4 × 4   —   16 kart · 8 par"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_btn_language" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnStartMemory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Zagraj →"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="@color/bg_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_btn_accent" />

    </LinearLayout>

</ScrollView>